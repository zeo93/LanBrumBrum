        <item name="textAppearanceLabelMedium">@style/Font.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/Font.LabelSmall</item>
    </style>

    <style name="Theme.GestoreVeicoli" parent="Base.Theme.GestoreVeicoli">
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#D8E6FF</item>
        <item name="colorOnPrimaryContainer">#062E6F</item>
        <item name="colorSecondary">#546E7A</item>
        <item name="colorTertiary">@color/rosso_ferrari</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="FotoArrotondata">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

