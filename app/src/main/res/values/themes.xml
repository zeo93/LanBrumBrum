<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base comune (font + statusbar); i colori stanno nelle varianti chiara/scura -->
    <style name="Base.Theme.GestoreVeicoli" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/naowh</item>
        <item name="fontFamily">@font/naowh</item>
        <item name="android:statusBarColor">@color/status_bar</item>

        <item name="textAppearanceDisplayLarge">@style/Font.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/Font.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/Font.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/Font.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/Font.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/Font.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/Font.TitleLarge</item>
